{
  "name": "@aio-proxy/provider-schemas",
  "version": "0.1.0",
  "description": "Generated JSON Schemas for AI SDK provider options",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "biome check .",
    "check:generated": "bun scripts/generate.ts --check",
    "check:security": "bun scripts/check-npm-security.ts --history",
    "ci": "bun run check:security && bun run ci:installed",
    "ci:installed": "bun run check && bun run check:generated && bun run typecheck && bun run test:unit && bun run build && bun run test:package",
    "generate": "bun scripts/generate.ts",
    "install:public": "bun install --registry=https://registry.npmjs.org --ignore-scripts",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run ci",
    "test": "bun run test:unit",
    "test:package": "bun test tests/runtime-leakage.test.ts",
    "test:unit": "bun test tests/public-api.test.ts tests/installed-provider-source.test.ts tests/declaration-parser.test.ts tests/schema-generator.test.ts tests/generate-command.test.ts tests/provider-catalog.test.ts tests/provider-sync.test.ts tests/npm-security.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@ai-sdk/alibaba": "2.0.9",
    "@ai-sdk/amazon-bedrock": "5.0.17",
    "@ai-sdk/anthropic": "4.0.12",
    "@ai-sdk/anthropic-aws": "2.0.4",
    "@ai-sdk/assemblyai": "3.0.7",
    "@ai-sdk/azure": "4.0.11",
    "@ai-sdk/baseten": "2.0.7",
    "@ai-sdk/black-forest-labs": "2.0.7",
    "@ai-sdk/bytedance": "2.0.8",
    "@ai-sdk/cerebras": "3.0.7",
    "@ai-sdk/cohere": "4.0.7",
    "@ai-sdk/deepgram": "3.0.7",
    "@ai-sdk/deepinfra": "3.0.7",
    "@ai-sdk/deepseek": "3.0.7",
    "@ai-sdk/elevenlabs": "3.0.8",
    "@ai-sdk/fal": "3.0.8",
    "@ai-sdk/fireworks": "3.0.8",
    "@ai-sdk/gateway": "4.0.16",
    "@ai-sdk/gladia": "3.0.7",
    "@ai-sdk/google": "4.0.12",
    "@ai-sdk/google-vertex": "5.0.16",
    "@ai-sdk/groq": "4.0.8",
    "@ai-sdk/huggingface": "2.0.7",
    "@ai-sdk/hume": "3.0.7",
    "@ai-sdk/klingai": "4.0.8",
    "@ai-sdk/lmnt": "3.0.7",
    "@ai-sdk/luma": "3.0.8",
    "@ai-sdk/mistral": "4.0.8",
    "@ai-sdk/moonshotai": "3.0.9",
    "@ai-sdk/open-responses": "2.0.7",
    "@ai-sdk/openai": "4.0.11",
    "@ai-sdk/openai-compatible": "3.0.7",
    "@ai-sdk/perplexity": "4.0.8",
    "@ai-sdk/prodia": "2.0.8",
    "@ai-sdk/quiverai": "2.0.7",
    "@ai-sdk/replicate": "3.0.8",
    "@ai-sdk/revai": "3.0.7",
    "@ai-sdk/togetherai": "3.0.8",
    "@ai-sdk/vercel": "3.0.7",
    "@ai-sdk/voyage": "2.0.7",
    "@ai-sdk/xai": "4.0.10",
    "@babel/parser": "7.28.5",
    "@biomejs/biome": "2.5.2",
    "@openrouter/ai-sdk-provider": "3.0.0",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.9",
    "typebox": "1.3.6",
    "typescript": "6.0.3"
  }
}
